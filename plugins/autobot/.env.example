# ============================================================
# Autobot Environment Variables
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# App Store Connect API Key (권장 방식)
# https://appstoreconnect.apple.com/access/integrations/api
# ------------------------------------------------------------
ASC_API_KEY_ID=          # API Key ID (예: XXXXXXXXXX)
ASC_API_ISSUER_ID=       # Issuer ID (예: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
ASC_API_KEY_PATH=        # .p8 키 파일 경로 (예: ~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8)

# ------------------------------------------------------------
# Apple ID 인증 (API Key 미사용 시 대안)
# App-Specific Password: https://appleid.apple.com → 앱 암호
# ------------------------------------------------------------
APPLE_ID=                # Apple ID 이메일 (예: your@email.com)
APP_SPECIFIC_PASSWORD=   # 앱 전용 비밀번호 (예: xxxx-xxxx-xxxx-xxxx)

# ------------------------------------------------------------
# Apple Developer Team
# 자동 감지되지만 명시적 설정도 가능
# ------------------------------------------------------------
DEVELOPMENT_TEAM=        # 팀 ID (예: A1B2C3D4E5)

# ------------------------------------------------------------
# TestFlight 테스터 초대
# '내부' 그룹에 자동 초대할 이메일
# ------------------------------------------------------------
TESTER_EMAIL=            # 테스터 Apple ID 이메일 (예: tester@email.com)
